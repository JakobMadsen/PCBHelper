# Copy to .env for local development.
# Do not commit real keys.

# Optional KiCad executable paths if auto-detection is not enough.
# KICAD_CLI=

# Optional deterministic simulator and autorouter dependencies.
# NGSPICE=
# JAVA_HOME=

# Required by the MCP server. Separate authorized roots with semicolons on Windows.
# PCBHELPER_ALLOWED_ROOTS=C:\PCB;D:\projects
# PCBHELPER_MCP_PROFILE=workflow
